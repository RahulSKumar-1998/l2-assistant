# ============================================================================
# GenAI L2 Support Assistant — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================================

# --- LLM Provider -----------------------------------------------------------
# Provider: "openai" (direct or Azure) or "anthropic"
LLM_PROVIDER=openai
# Model identifier (e.g., gpt-4o, claude-3-5-sonnet-20241022)
LLM_MODEL_NAME=gpt-4o

# OpenAI direct API key (used when LLM_PROVIDER=openai and no Azure endpoint)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Azure OpenAI (used when LLM_PROVIDER=openai and AZURE_OPENAI_ENDPOINT is set)
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01

# Anthropic API key (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- Embedding Model --------------------------------------------------------
# Model name for generating text embeddings
EMBEDDING_MODEL=text-embedding-3-large
# Embedding vector dimensions (3072 for text-embedding-3-large)
EMBEDDING_DIMENSIONS=3072

# --- Vector Store ------------------------------------------------------------
# Provider: "pinecone" or "pgvector"
VECTOR_STORE_PROVIDER=pinecone

# Pinecone settings (used when VECTOR_STORE_PROVIDER=pinecone)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=l2-assistant-index
PINECONE_ENVIRONMENT=us-east-1-aws

# --- ServiceNow -------------------------------------------------------------
# ServiceNow instance base URL
SNOW_INSTANCE_URL=https://your-instance.service-now.com
# Service account credentials for API access
SNOW_USERNAME=svc_ai_assistant
SNOW_PASSWORD=your-servicenow-password-here
# OAuth client credentials (preferred over basic auth)
SNOW_CLIENT_ID=your-client-id-here
SNOW_CLIENT_SECRET=your-client-secret-here
# HMAC secret for webhook signature validation
SNOW_WEBHOOK_SECRET=your-webhook-hmac-secret-here

# --- Database ----------------------------------------------------------------
# PostgreSQL async connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://l2assistant:l2assistant@localhost:5432/l2assistant
# Redis connection string (for caching and Celery broker)
REDIS_URL=redis://localhost:6379/0

# --- Application Settings ---------------------------------------------------
# Environment: development | staging | production
APP_ENV=development
# Log format: "human" (pretty-printed) or "json" (structured)
LOG_FORMAT=human
# Secret key for session management and HMAC operations
SECRET_KEY=change-this-to-a-random-secret-key
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://your-instance.service-now.com

# --- Observability -----------------------------------------------------------
# LangSmith API key for LLM tracing (optional, leave empty to disable)
LANGSMITH_API_KEY=
# LangSmith project name for organizing traces
LANGSMITH_PROJECT=l2-assistant-dev
# Enable Prometheus metrics endpoint at /metrics
PROMETHEUS_ENABLED=true
