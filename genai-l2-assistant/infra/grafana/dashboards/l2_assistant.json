      "type": "histogram",
      "id": 3,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(l2_confidence_score_bucket[1h])) by (le)",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ],
      "options": {
        "bucketSize": 0.1,
        "combine": false,
        "fillOpacity": 80,
        "gradientMode": "scheme",
        "legend": { "displayMode": "list" }
      }
    },
    {
      "title": "Feedback Rate (Positive vs Negative)",
      "type": "timeseries",
      "id": 4,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "feedback/hour",
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Positive" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Negative" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(l2_feedback_total{rating=\"5\"}[1h])) * 3600",
          "legendFormat": "Positive",
          "refId": "A"
        },
        {
          "expr": "sum(rate(l2_feedback_total{rating=\"1\"}[1h])) * 3600",
          "legendFormat": "Negative",
          "refId": "B"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
