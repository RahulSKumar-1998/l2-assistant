            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.15 },
              { "color": "red", "value": 0.30 }
            ]
          },
          "unit": "percentunit",
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(l2_escalation_total[1h])) / sum(rate(l2_incidents_analyzed_total[1h]))",
          "legendFormat": "Escalation Rate",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
